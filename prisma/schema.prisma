// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String
  password String
  phone    String? @unique

  currencyCode String @default("INR") @map("currency_code") @db.VarChar(3)
  timezone     String @default("Asia/Kolkata")

  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedTime DateTime  @updatedAt @map("updated_at")

  monthlyIncome Decimal? @map("monthly_income") @db.Decimal(12, 2)

  emailNotifications Boolean   @default(true) @map("email_notifications")
  pushNotifications  Boolean   @default(true) @map("push_notifications")
  emailVerified      Boolean   @default(false) @map("email_verified")
  otpCode            String?
  otpExpiry          DateTime?
  resetCode          String?
  resetCodeExpiry    DateTime?

  subscriptions           Subscription[]
  notificationPreferences NotificationPreference[]
  sentNotifications       SentNotification[]
  budgets                 Budget[]

  @@map("users")
}

model Subscription {
  id     String @id @default(cuid())
  userId String @map("user_id")

  name        String  @db.VarChar(255)
  description String? @db.Text
  category    String  @db.VarChar(100)
  logoUrl     String? @map("logo_url") @db.Text
  websiteUrl  String? @map("website_url") @db.Text

  amount       Decimal      @db.Decimal(10, 2)
  currency     String       @default("INR") @db.VarChar(3)
  billingCycle BillingCycle @map("billing_cycle")

  firstBillingDate DateTime @map("first_billing_date")
  lastBillingDate  DateTime @map("last_billing_date")
  nextBillingDate  DateTime @map("next_billing_date")

  status    SubscriptionStatus @default(ACTIVE)
  autoRenew Boolean            @default(true) @map("auto_renew")

  lastPaidDate  DateTime?      @map("last_paid_date")
  paymentStatus PaymentStatus  @default(PENDING) @map("payment_status")
  paymentMethod PaymentMethod? @map("payment_method")

  lastUsedDate   DateTime?      @map("last_used_date")
  usageFrequency UsageFrequency @default(MONTHLY) @map("usage_frequency")

  billType   BillType @default(FIXED) @map("bill_type")
  isVariable Boolean  @default(false) @map("is_variable")
  billingDay Int?     @map("billing_day") // Day of month when bill is generated

  notes        String? @db.Text
  reminderDays Int     @default(3) @map("reminder_days")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingHistory    BillingHistory[]
  notifications     NotificationPreference[]
  billRecords       BillRecord[]
  billEstimates     BillEstimate[]
  sentNotifications SentNotification[]

  @@index([userId])
  @@index([userId, status])
  @@index([nextBillingDate])
  @@index([paymentStatus, nextBillingDate]) // For "overdue bills" query
  @@map("subscriptions")
}

model BillingHistory {
  id             String @id @default(cuid())
  subscriptionId String @map("subscription_id")

  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @db.VarChar(3)
  billingDate DateTime @map("billing_Date")

  paymentStatus PaymentStatus  @default(PENDING) @map("payment_status")
  paymentMethod PaymentMethod? @map("payment_method")
  transactionId String?        @map("tranasaction_id") @db.VarChar(255)

  notes String? @db.Text

  createdAt    DateTime     @default(now()) @map("created_at")
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([billingDate])
  @@index([subscriptionId])
  @@map("billing_history")
}

model NotificationPreference {
  id             String  @id @default(cuid())
  userId         String  @map("user_id")
  subscriptionId String? @map("subscription_id")

  reminderDaysBefore Int     @default(3) @map("reminder_days_before")
  enabled            Boolean @default(true)

  sendEmail Boolean @default(true) @map("send_email")
  sendPush  Boolean @default(true) @map("send_push")
  sendSms   Boolean @default(false) @map("send_sms")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([userId, subscriptionId])
  @@index([userId])
  @@map("notification_preferences")
}

model BillRecord {
  id             String @id @default(cuid())
  subscriptionId String @map("subscription_id")

  billingMonth  DateTime      @map("billing_month") // Which month this bill is for
  amount        Decimal       @db.Decimal(10, 2)
  unitsConsumed Decimal?      @map("units_consumed") @db.Decimal(10, 2) // kWh, liters, etc.
  billDate      DateTime      @map("bill_date") // When bill was generated
  dueDate       DateTime?     @map("due_date")
  paidDate      DateTime?     @map("paid_date")
  billImageUrl  String?       @map("bill_image_url") @db.Text
  billPdfUrl    String?       @map("bill_pdf_url") @db.Text
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  notes String? @db.Text

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, billingMonth])
  @@index([subscriptionId])
  @@index([billingMonth])
  @@map("bill_history")
}

model BillEstimate {
  id             String @id @default(cuid())
  subscriptionId String @map("subscription_id")

  billingMonth       DateTime         @map("billing_month") // First day of month being estimated
  estimatedAmount    Decimal          @db.Decimal(10, 2)
  estimationMethod   EstimationMethod @map("estimation_method")
  confidenceScore    Decimal?         @map("confidence_score") @db.Decimal(3, 2) // 0.00 to 1.00
  minAmount          Decimal?         @map("min_amount") @db.Decimal(10, 2) // Estimated range minimum
  maxAmount          Decimal?         @map("max_amount") @db.Decimal(10, 2) // Estimated range maximum
  actualAmount       Decimal?         @map("actual_amount") @db.Decimal(10, 2) // Filled when actual bill arrives
  variance           Decimal?         @map("variance") @db.Decimal(10, 2) // actual - estimated
  variancePercentage Decimal?         @map("variance_percentage") @db.Decimal(5, 2)

  notes String? @db.Text

  estimatedAt      DateTime  @default(now()) @map("estimated_at") // When estimate was made
  actualRecordedAt DateTime? @map("actual_recorded_at") // When actual was entered

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, billingMonth])
  @@index([subscriptionId])
  @@index([billingMonth])
  @@map("bill_estimates")
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum BillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  ONE_TIME
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  SKIPPED
  OVERDUE
}

enum UsageFrequency {
  DAILY
  WEEKLY
  MONTHLY
  RARELY
  NEVER
}

enum BillType {
  FIXED
  VARIABLE
}

enum EstimationMethod {
  MANUAL
  HISTORICAL_AVG
  WEIGHTED_AVG
  SEASONAL_AVG
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  CASH
  BANK_TRANSFER
  OTHER
}

model SentNotification {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  subscriptionId String   @map("subscription_id")

  type    String @db.VarChar(50)  // "BILL_REMINDER", "OVERDUE_ALERT"
  channel String @db.VarChar(20)  // "EMAIL"

  sentAt   DateTime @default(now()) @map("sent_at")
  metadata String?  @db.Text       // JSON for extra context

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([userId, subscriptionId, type, sentAt])
  @@index([sentAt])
  @@map("sent_notifications")
}

model Budget {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  category String   @db.VarChar(100)
  limit    Decimal  @db.Decimal(12, 2)
  month    DateTime @map("budget_month")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses BudgetExpense[]

  @@unique([userId, category, month])
  @@index([userId, month])
  @@map("budgets")
}

model BudgetExpense {
  id          String   @id @default(cuid())
  budgetId    String   @map("budget_id")
  description String   @db.VarChar(255)
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime
  notes       String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@index([budgetId, date])
  @@map("budget_expenses")
}
